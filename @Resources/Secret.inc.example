; --- Notion Assignments ---
; Share the target database/data source with your internal integration first.
; Token: create an internal integration and paste its installation access token here.
; Data source id: this is the assignments data source id used by the skin query endpoint.

NotionIntegrationToken=REPLACE_WITH_YOUR_NOTION_TOKEN
NotionDataSourceId=REPLACE_WITH_YOUR_NOTION_DATA_SOURCE_ID
